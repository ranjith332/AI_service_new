NODE_ENV=development
PORT=3000
SERVICE_NAME=doctor-healix-ai-service
APP_TIMEZONE=Asia/Calcutta
CORS_ORIGIN=*

DB_CLIENT=mysql
DATABASE_URL=mysql://root:root@localhost:3306/doctor_healix
DB_POOL_MIN=1
DB_POOL_MAX=10

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
NVIDIA_QWEN_API_KEY=
NVIDIA_QWEN_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_QWEN_MODEL=qwen/qwen3-next-80b-a3b-instruct
LLM_TIMEOUT_MS=30000

QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=doctor_healix_healthcare
VECTOR_SIZE=3072
VECTOR_RESULT_LIMIT=5

ENABLE_QUERY_CACHE=true
CACHE_TTL_SECONDS=60
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=30

AUTH_REQUIRED=false
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=sandbox
CASHFREE_API_VERSION=2025-01-01
CASHFREE_RETURN_URL=https://example.com/payments/cashfree/return
CASHFREE_NOTIFY_URL=https://example.com/payments/cashfree/webhook
SCHEMA_MAPPING_PATH=./config/schema-mapping.local.json
INGESTION_STATE_PATH=./config/ingestion-state.local.json
