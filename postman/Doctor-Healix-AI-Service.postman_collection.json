          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tenant_id\": \"{{tenantId}}\",\n  \"user_query\": \"Show the latest 10 token transactions for this hospital\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/ai/query",
