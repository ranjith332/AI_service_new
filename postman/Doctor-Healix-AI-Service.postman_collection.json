          "raw": "{\n  \"tenant_id\": \"{{tenantId}}\",\n  \"user_query\": \"Show today's appointments\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/ai/query",
          "host": ["{{baseUrl}}"],
          "path": ["ai", "query"]
        }
      }
    },
